# Node.js backend .gitignore
# Generated: keeps dependencies, logs, build artifacts, and secrets out of Git

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/

# Coverage and test output
coverage/
.nyc_output/

# Build output
dist/
build/
out/

# Dependencies
node_modules/
jspm_packages/

# Environment files
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE / Editor folders
.vscode/
.idea/
*.sublime-workspace

# Misc
*.tgz
.cache/
.cache-loader/
.sass-cache/

# Database files (uncomment if you want to ignore local DB files)
# *.sqlite
# *.sqlite3
# *.db
# *.db-journal

# Puppeteer/Chromium caches (if used by scraper)
.local-chromium/
.cache/puppeteer

